{
  "name": "aarhus-grocery-deals",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Mobile-first Aarhus grocery deal pocketbook with automated flyer updates.",
  "scripts": {
    "update": "node scripts/update-data.mjs && node scripts/update-product-identities.mjs",
    "update:fallback": "npm run update:stores",
    "update:stores": "node scripts/update-selected-stores.mjs",
    "update:atlanta:archive": "node scripts/update-atlanta-data.mjs && node scripts/sync-atlanta-product-knowledge.mjs",
    "validate": "node scripts/validate-data.mjs",
    "audit:taxonomy": "node scripts/audit-human-taxonomy.mjs",
    "check": "npm test && npm run audit:taxonomy && npm run validate",
    "test": "node --test",
    "serve": "python3 -m http.server 8080",
    "locate": "node scripts/apply-source-locators.mjs",
    "build:preview": "node scripts/build-preview.mjs",
    "descriptions:sync": "node scripts/queue-product-descriptions.mjs",
    "descriptions:clean": "node scripts/clean-item-descriptions.mjs",
    "identities:update": "node scripts/update-product-identities.mjs",
    "taxonomy:sync": "node scripts/sync-product-taxonomy.mjs",
    "taxonomy:reconcile": "node scripts/reconcile-pending-taxonomy.mjs",
    "taxonomy:migrate": "node scripts/migrate-category-splits.mjs && node scripts/update-product-identities.mjs",
    "atlanta-knowledge:sync": "node scripts/sync-atlanta-product-knowledge.mjs",
    "review:products": "node scripts/codex-review-current-products.mjs && node scripts/update-product-identities.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
